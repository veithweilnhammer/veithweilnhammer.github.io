library("geepack")
No_NA_Data <-
Data[!is.na(Data$Perception) & !is.na(Data$Previous_Perception), ]
gee_log <-
geeglm(
Perception ~ w_Stimulus + Previous_Perception,
id = ID,
data = No_NA_Data,
family = binomial,
corstr = "ind"
)
summary(gee_log)
