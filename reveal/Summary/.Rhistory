library(lme4)
library(afex)
## Runwise Stats
MM.Mean_accuracy_adaptive_runs <- lmer(Mean_Accuracy ~ Run  + (1|ID), Runwise_Data[Runwise_Data$SAR == "Adaptive",])
MM.Mean_Memory_adaptive_runs <- lmer(Mean_Memory ~ Run  + (1|ID), Runwise_Data[Runwise_Data$SAR == "Adaptive",])
T.Mean_accuracy_fixed_runs <- t.test(Runwise_Data[Runwise_Data$Run == 5,]$Mean_Accuracy, Runwise_Data[Runwise_Data$Run == 6,]$Mean_Accuracy, paired = TRUE)
T.Mean_Memory_fixed_runs <- t.test(Runwise_Data[Runwise_Data$Run == 5,]$Mean_Memory, Runwise_Data[Runwise_Data$Run == 6,]$Mean_Memory, paired = TRUE)
## Levelwise Stats
MM.Mean_accuracy_adaptive_levels <- lmer(Accuracy ~ SAR_Percent  + (1|ID), Levelwise_Data)
MM.Mean_Memory_adaptive_levels <- lmer(Memory ~ SAR_Percent  + (1|ID), Levelwise_Data)
## Correation
Corr.accuracy_Memory_fixed_runs <- cor.test(Runwise_Data[Runwise_Data$SAR == "Fixed",]$Mean_Accuracy, Runwise_Data[Runwise_Data$SAR == "Fixed",]$Mean_Memory, method = "pearson")
