add = "reg.line",
conf.int = TRUE,
# Add confidence interval
cor.coef = FALSE,
fullrange = FALSE,                         # Extending the regression line
rug = TRUE,
color = "black", #c("#377EB8"),
shape = 20,
size = 1,
alpha = 0.7
) +
theme(
axis.title.x = element_text(size = 8),
axis.text.x  = element_text(size = 8),
axis.title.y = element_text(size = 8),
axis.text.y  = element_text(size = 8)
) +
theme_classic(base_size = 8) + labs(x = "Stimulus-congruent",  y =
"History-congruent", subtitle = "B")  + xlim(55,100) + ylim(40,100) +
geom_hline(
yintercept = 50,
linetype = "dashed",
color = "black",
size = 0.5) +
geom_vline(
xintercept = 0.5,
linetype = "dashed",
color = "black",
size = 0.5)
## AIC of logistic regression
p_LogReg_Data <- ggplot() +
