## combine real and simulated data for visualization
average_simulated_acf[average_simulated_acf == "NaN"] = NA
Aggr_average_simulated_acf <-
ddply(
average_simulated_acf,
.(Trial),
summarise,
mean_acf_Stimulus = mean(Stimulus, na.rm = TRUE),
se_acf_Stimulus = sd(Stimulus, na.rm = TRUE)/sqrt(length(Stimulus)),
mean_acf_History = mean(History, na.rm = TRUE),
se_acf_History = sd(History, na.rm = TRUE)/sqrt(length(History))
)
gathercol <- colnames(Aggr_average_simulated_acf[,c(2,4)])
Aggr_average_simulated_acf_long <-
gather(Aggr_average_simulated_acf[, c(1,2,4)],
"Type",
"ACF",
gathercol,
factor_key = FALSE)
Aggr_average_simulated_acf_long$SE <- c(Aggr_average_simulated_acf$se_acf_Stimulus, Aggr_average_simulated_acf$se_acf_History)
Aggr_average_simulated_acf_long <- rbind(Aggr_average_simulated_acf_long, Acf_Data_long[,c(1,2, 3, 4)])
Aggr_average_simulated_acf_long$Data <- c(rep("Simulated", 240), rep("Real", 240))
Aggr_average_simulated_acf_long$Type[Aggr_average_simulated_acf_long$Type == "mean_acf_Stimulus"] = "Stimulus-congruence"
Aggr_average_simulated_acf_long$Type[Aggr_average_simulated_acf_long$Type == "mean_acf_History"] = "History-congruence"
Aggr_average_simulated_acf_long$Type <- as.factor(Aggr_average_simulated_acf_long$Type)
levels(Aggr_average_simulated_acf_long$Type) <- c("Stimulus-congruence", "History-congruence")
p_acf_sim <- ggplot(data = Aggr_average_simulated_acf_long[Acf_Data_long$Trial != 1, ],
aes(
x = Trial,
stat = "identity",
y = ACF,
color = Data,
flll = Data
)) +
geom_errorbar(
data = Aggr_average_simulated_acf_long[Acf_Data_long$Trial != 1, ],
aes(
x = Trial,
stat = "identity",
ymax = ACF + SE,
ymin = ACF - SE
),
alpha = 0.5
) +
geom_line(
data = Aggr_average_simulated_acf_long[Acf_Data_long$Trial != 1, ],
aes(
x = Trial,
stat = "identity",
y = ACF,
color = Data
),
alpha = 0.5
) + scale_shape_manual(values = c(2, 1)) + theme_classic(base_size = 8) + scale_color_brewer(palette = "Accent", direction = 1) +
scale_fill_brewer(palette = "Accent", direction = 1) +
labs(x = "Trial",  y = "Autocorrelation coefficient", subtitle = "B") +
geom_hline(
yintercept = 0,
linetype = "dashed",
color = "black",
size = 0.5
) +
theme(legend.position = "none") + ylim(-0.1, 0.2) + stat_smooth(method = "loess", size = 0.6, alpha = 0.5) + facet_wrap( ~
Type)
lay <- rbind(c(1, 2), c(3))
grid.arrange(
p_Sim_Real_Outcomes, p_acf_sim, p_Sim_Real_Rel_Modes,
layout_matrix = lay,
heights = c(1,1.5),
widths = c(1,1)
)
